<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In — SupportDesk</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/app.js" defer></script>
</head>
<body>
<div class="auth-theme">
  <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme">
    <span class="theme-icon">☀️</span>
  </button>
</div>
<div class="auth-shell">
  <div class="auth-card">
    <div class="auth-logo">
      <h1>SupportDesk</h1>
      <p>Sign in to your <span class="mono">agent</span> account</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/login" method="POST">
      <div class="form-group">
        <label class="form-label" for="email">Email address</label>
        <input type="email" id="email" name="email" class="form-control" placeholder="you@company.com" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label" for="password">Password</label>
        <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; margin-top:4px;">
        Sign in
      </button>
    </form>

    <div class="auth-footer">
      No account yet? <a href="/register">Create one</a>
    </div>
  </div>
</div>
</body>
</html>
