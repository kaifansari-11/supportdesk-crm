<%- include('partials/header', { pageTitle: 'Dashboard', activePage: 'dashboard' }) %>

<div class="page-header">
  <div>
    <h2>Dashboard</h2>
    <p>Welcome back, <%= user.name %>. Here's today's overview.</p>
  </div>
  <a href="/tickets/new" class="btn btn-primary">
    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    New Ticket
  </a>
</div>

<!-- STAT CARDS -->
<div class="stat-grid">
  <div class="stat-card">
    <div class="stat-label">Total Tickets</div>
    <div class="stat-value"><%= stats.total || 0 %></div>
    <div class="stat-sub">All time</div>
  </div>
  <div class="stat-card open">
    <div class="stat-label">Open</div>
    <div class="stat-value"><%= stats.open || 0 %></div>
    <div class="stat-sub">Awaiting action</div>
  </div>
  <div class="stat-card progress">
    <div class="stat-label">In Progress</div>
    <div class="stat-value"><%= stats.in_progress || 0 %></div>
    <div class="stat-sub">Being worked on</div>
  </div>
  <div class="stat-card closed">
    <div class="stat-label">Closed</div>
    <div class="stat-value"><%= stats.closed || 0 %></div>
    <div class="stat-sub">Resolved</div>
  </div>
</div>

<!-- RECENT TICKETS -->
<div class="card">
  <div class="card-title">Recent tickets</div>
  <% if (recent.length === 0) { %>
    <div class="empty-state">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      <h3>No tickets yet</h3>
      <p>Create your first support ticket to get started.</p>
    </div>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Ticket ID</th>
          <th>Customer</th>
          <th>Subject</th>
          <th>Status</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% recent.forEach(ticket => { %>
        <tr>
          <td><span class="ticket-id"><%= ticket.ticket_id %></span></td>
          <td><%= ticket.customer_name %></td>
          <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= ticket.subject %></td>
          <td>
            <% if (ticket.status === 'Open') { %>
              <span class="badge badge-open">Open</span>
            <% } else if (ticket.status === 'In Progress') { %>
              <span class="badge badge-progress">In Progress</span>
            <% } else { %>
              <span class="badge badge-closed">Closed</span>
            <% } %>
          </td>
          <td><%= new Date(ticket.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %></td>
          <td><a href="/tickets/<%= ticket.ticket_id %>" class="btn btn-outline btn-sm">View</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div style="margin-top:14px">
    <a href="/tickets" class="btn btn-outline btn-sm">View all tickets →</a>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
