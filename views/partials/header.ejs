<!DOCTYPE html>
<html lang="en" data-theme="dark">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= typeof pageTitle !=='undefined' ? pageTitle + ' — SupportDesk' : 'SupportDesk CRM' %>
  </title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/app.js" defer></script>
</head>

<body>
  <div class="app-shell">
    <!-- sidebar  -->
    <aside class="sidebar">
      <div class="sidebar-brand">
        <h1>SupportDesk</h1>
        <span>CRM v1.0</span>
      </div>
      <nav class="sidebar-nav">
        <span class="nav-section-label">Main</span>
        <a href="/"
          class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
          </svg>
          Dashboard
        </a>
        <a href="/tickets"
          class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'tickets' ? 'active' : '' %>">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path
              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          All Tickets
        </a>
        <span class="nav-section-label">Actions</span>
        <a href="/tickets/new"
          class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'new' ? 'active' : '' %>">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="16" />
            <line x1="8" y1="12" x2="16" y2="12" />
          </svg>
          New Ticket
        </a>
      </nav>
      <div class="sidebar-footer">
        <% if (user) { %>
          <div class="user-chip">
            <div class="user-avatar">
              <%= user.name.charAt(0).toUpperCase() %>
            </div>
            <div>
              <div class="user-name">
                <%= user.name %>
              </div>
              <div class="user-role">Support Agent</div>
            </div>
          </div>
          <form action="/logout" method="POST">
            <button type="submit" class="btn-logout">Sign out</button>
          </form>
          <% } %>
      </div>
    </aside>

    <!-- main  -->
    <div class="main">
      <div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>

      <header class="topbar">
        <div class="topbar-left">
          <button class="menu-toggle" onclick="toggleSidebar()" title="Open Menu">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <span class="page-title">
            <%= typeof pageTitle !=='undefined' ? pageTitle : 'Dashboard' %>
          </span>
        </div>
        <div class="topbar-right">
          <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme">
            <span class="theme-icon">☀️</span>
          </button>
        </div>
      </header>
      
      <main class="content">